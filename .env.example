# ============================================
# 🏛️ ARTEMIS CITY - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

# ============================================
# 🔐 MCP SERVER CONFIGURATION
# ============================================

# MCP Server base URL (default: http://localhost:3000)
MCP_BASE_URL=http://localhost:3000

# MCP API Key for authentication (required)
# Generate a secure random key: openssl rand -hex 32
MCP_API_KEY=your_secure_api_key_here

# ============================================
# 📚 OBSIDIAN CONFIGURATION
# ============================================

# Obsidian Local REST API base URL
# Default when running locally: http://localhost:27124
# Docker on Mac/Windows: http://host.docker.internal:27124
OBSIDIAN_BASE_URL=http://localhost:27124

# Obsidian Local REST API Key
# Get this from Obsidian -> Settings -> Local REST API
OBSIDIAN_API_KEY=your_obsidian_api_key_here

# ============================================
# 🔧 OPTIONAL CONFIGURATION
# ============================================

# MCP Server Port (if running the server)
PORT=3000

# Log Level: DEBUG, INFO, WARN, ERROR
MCP_LOG_LEVEL=INFO

# Python virtual environment path (if non-standard)
VIRTUAL_ENV=
# ============================================
# EXO CLUSTER (local LLM inference)
# ============================================

# EXO API base URL (default: http://localhost:52415)
EXO_BASE_URL=http://localhost:52415

# Explicit model ID — leave blank to auto-detect from the running cluster
EXO_MODEL_ID=

# ============================================
# EXTERNAL API KEYS (Add as needed)
# ============================================

# OpenAI API Key (if using AI features)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (if using Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub Personal Access Token (if using GitHub integration)
# GITHUB_TOKEN=ghp_...

# Other API keys as needed
# SERVICE_API_KEY=...
